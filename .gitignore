# =============================================================================
# Dependencies
# =============================================================================
node_modules/
package-lock.json
yarn.lock

# =============================================================================
# Build outputs
# =============================================================================
dist/
build/
.next/
out/
*.tsbuildinfo

# =============================================================================
# Environment variables  (commit .env.example, never .env)
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Database — SQLite files must never be committed
# =============================================================================
*.db
*.db-journal
*.db-wal
*.db-shm

# =============================================================================
# Generated files (Prisma client, codegen output, etc.)
# =============================================================================
**/generated/

# =============================================================================
# Test / coverage artifacts
# =============================================================================
coverage/
.nyc_output/
*.lcov

# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Editor / IDE  (each contributor uses their own settings)
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# =============================================================================
# Temporary / cache
# =============================================================================
tmp/
temp/
.temp/
.tmp/
.cache/
.vite/
*.tgz
pids/
*.pid
*.seed
*.pid.lock

# =============================================================================
# Claude Code — local machine settings only; CLAUDE.md is committed
# =============================================================================
.claude/settings.local.json