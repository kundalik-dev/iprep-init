            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/interview/{{sessionId}}/end",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "interview", "{{sessionId}}", "end"]
