    {
      "name": "Interview",
      "description": "Interview session lifecycle routes. The primary collection shape uses /api/v1/interview and /api/v1/interview/:id as requested.",
      "item": [
        {
          "name": "List Interview Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/interview",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "interview"]
            },
            "description": "Inferred from MockAPI.getSessions() for the demo history/dashboard views."
          },
          "response": []
        },
        {
          "name": "Start Interview",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageSlug\": \"behavioral\",\n  \"tutorSlug\": \"priya\",\n  \"mode\": \"voice\",\n  \"preferences\": {\n    \"autoAnalyzeOnEnd\": true,\n    \"voiceEnabled\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/interview",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "interview"]
            },
            "description": "RESTful v1 equivalent of MockAPI.startSession(pkg, tutor). The older architecture docs also mention POST /api/interview/start."
          },
          "response": []
        },
        {
          "name": "Start Interview - Legacy Path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageSlug\": \"technical\",\n  \"tutorSlug\": \"alex\",\n  \"mode\": \"text\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/interview/start",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "interview", "start"]
            },
            "description": "Included because backend-architecture.md documents POST /api/interview/start."
          },
          "response": []
        },
        {
          "name": "Get Interview By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/interview/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "interview", "{{sessionId}}"]
            },
            "description": "Matches http://localhost:3000/api/v1/interview/:id."
          },
          "response": []
