            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Behavioral prep notes\",\n  \"type\": \"md\",\n  \"folderId\": \"{{folderId}}\",\n  \"contentMarkdown\": \"# STAR Stories\\n\\n\"\n}"
